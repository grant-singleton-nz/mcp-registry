{
  "rewrites": [
    { "source": "/v0.1/servers", "destination": "/servers.json" },
    { "source": "/v0.1/servers/", "destination": "/servers.json" },
    { "source": "/v0.1/servers/io.github.grant-singleton-nz%2Fexample-server/versions/latest", "destination": "/servers-example-server-latest.json" },
    { "source": "/v0.1/servers/io.github.grant-singleton-nz%2Fexample-server/versions/1.0.0", "destination": "/servers-example-server-latest.json" },
    { "source": "/v0.1/servers/io.github.grant-singleton-nz/example-server/versions/latest", "destination": "/servers-example-server-latest.json" },
    { "source": "/v0.1/servers/io.github.grant-singleton-nz/example-server/versions/1.0.0", "destination": "/servers-example-server-latest.json" },
    { "source": "/v0.1/servers/:name/versions/:version", "destination": "/servers-example-server-latest.json" }
  ],
  "headers": [
    {
      "source": "/v0.1/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Authorization, Content-Type" },
        { "key": "Content-Type", "value": "application/json" }
      ]
    },
    {
      "source": "/manifests/:path*",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "cleanUrls": true
}